{
  "name": "slidev-addon-pacer",
  "version": "0.6.0",
  "description": "Slidev addon for presentation time management: dual-lane race, per-slide time budgets, time banking, and target completion tracking.",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.5.0"
  },
  "workspaces": [
    "example"
  ],
  "scripts": {
    "dev": "slidev ./example/slides.md --remote 0.0.0.0",
    "build": "slidev build example.md",
    "export": "slidev export example.md",
    "screenshot": "slidev export example.md --format png",
    "test": "echo there is no test."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyperscaleav/slidev-addon-pacer.git"
  },
  "keywords": [
    "slidev-addon",
    "slidev",
    "presentation",
    "timer",
    "pacing"
  ],
  "author": "Hyperscale AV",
  "license": "MIT",
  "devDependencies": {
    "@slidev/cli": "^0.49.29",
    "@slidev/theme-default": "^0.25.0"
  },
  "dependencies": {
    "@iconify-json/emojione-monotone": "^1.1.4",
    "@iconify-json/mdi": "^1.2.3"
  },
  "bugs": {
    "url": "https://github.com/hyperscaleav/slidev-addon-pacer/issues"
  },
  "homepage": "https://github.com/hyperscaleav/slidev-addon-pacer#readme"
}
